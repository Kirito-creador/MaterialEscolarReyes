@model MaterialEscolarReyes.ViewModels.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>

<html>

<head>

    <meta charset="utf-8" />

    <title>Material Escolar Reyes</title>

    <meta name="viewport" content="width=device-width, initial-scale=1">


    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">



    <style>

            body{

            height:100vh;

            display:flex;

            justify-content:center;

            align-items:center;

            background:linear-gradient(135deg,#667eea,#764ba2);

            }


            .card{

            border:none;

            border-radius:20px;

            box-shadow:0 10px 30px rgba(0,0,0,.3);

            }


            .logo{

            font-size:50px;

            color:#667eea;

            }


    </style>



</head>

<body>



    <div class="col-md-4">


        <div class="card p-4">


            <div class="text-center">


                <i class="bi bi-shop logo"></i>


                <h3>

                    Material Escolar Reyes

                </h3>


                <p>

                    Sistema de Inventario

                </p>


            </div>



            <form asp-action="Login">


                <div class="mb-3">


                    <label>

                        Correo

                    </label>


                    <input asp-for="Correo"
                           class="form-control" />



                    <span asp-validation-for="Correo"
                          class="text-danger">


                    </span>


                </div>



                <div class="mb-3">


                    <label>

                        Contraseña

                    </label>



                    <input asp-for="Password"
                           class="form-control" />


                    <span asp-validation-for="Password"
                          class="text-danger">


                    </span>


                </div>



                @if (ViewBag.Error != null)
                {

                    <div class="alert alert-danger">

                        @ViewBag.Error

                    </div>

                }



                <button class="btn btn-primary w-100">


                    Ingresar


                </button>



            </form>



        </div>


    </div>


</body>

</html>