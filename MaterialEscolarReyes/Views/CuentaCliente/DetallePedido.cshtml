@model IEnumerable<MaterialEscolarReyes.Models.DetallePedido>

@{
    ViewData["Title"] = "Detalle de Compra";
    Layout = "~/Views/Shared/_LayoutTienda.cshtml";

    decimal total = 0;
}

<div class="container py-5">

    <h2 class="fw-bold mb-4">

        <i class="bi bi-receipt"></i>

        Detalle de la Compra

    </h2>

    @if (!Model.Any())
    {
        <div class="alert alert-warning">

            No existen productos en este pedido.

        </div>
    }
    else
    {
        <table class="table table-bordered table-hover align-middle">

            <thead class="table-dark">

                <tr>

                    <th>Producto</th>

                    <th>Cantidad</th>

                    <th>Precio</th>

                    <th>Subtotal</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    decimal subtotal = item.Cantidad * item.Precio;

                    total += subtotal;

                    <tr>

                        <td>

                            @item.Producto?.Nombre

                        </td>

                        <td>

                            @item.Cantidad

                        </td>

                        <td>

                            Bs @item.Precio

                        </td>

                        <td>

                            Bs @subtotal

                        </td>

                    </tr>
                }

            </tbody>

        </table>

        <div class="text-end">

            <h3 class="text-success">

                Total: Bs @total

            </h3>

        </div>

        <a asp-action="MisPedidos"
           class="btn btn-secondary mt-3">

            <i class="bi bi-arrow-left"></i>

            Volver

        </a>
    }

</div>