@model MaterialEscolarReyes.ViewModels.RegistroClienteViewModel

@{
    ViewData["Title"] = "Crear Cuenta";
    Layout = "~/Views/Shared/_LayoutTienda.cshtml";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-6">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-body p-5">

                    <h2 class="text-center fw-bold mb-4">
                        Crear Cuenta
                    </h2>

                    <form asp-action="Registro" method="post">

                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3"></div>

                        <div class="row">

                            <div class="col-md-6 mb-3">

                                <label asp-for="Nombre"></label>

                                <input asp-for="Nombre" class="form-control" />

                                <span asp-validation-for="Nombre"
                                      class="text-danger"></span>

                            </div>

                            <div class="col-md-6 mb-3">

                                <label asp-for="Apellido"></label>

                                <input asp-for="Apellido" class="form-control" />

                                <span asp-validation-for="Apellido"
                                      class="text-danger"></span>

                            </div>

                        </div>

                        <div class="mb-3">

                            <label asp-for="Correo"></label>

                            <input asp-for="Correo"
                                   class="form-control" />

                            <span asp-validation-for="Correo"
                                  class="text-danger"></span>

                        </div>

                        <div class="mb-3">

                            <label asp-for="Telefono"></label>

                            <input asp-for="Telefono"
                                   class="form-control" />

                        </div>

                        <div class="mb-3">

                            <label asp-for="Direccion"></label>

                            <input asp-for="Direccion"
                                   class="form-control" />

                        </div>

                        <div class="mb-3">

                            <label asp-for="Password"></label>

                            <input asp-for="Password"
                                   class="form-control" />

                            <span asp-validation-for="Password"
                                  class="text-danger"></span>

                        </div>

                        <div class="mb-4">

                            <label asp-for="ConfirmarPassword"></label>

                            <input asp-for="ConfirmarPassword"
                                   class="form-control" />

                            <span asp-validation-for="ConfirmarPassword"
                                  class="text-danger"></span>

                        </div>

                        <button class="btn btn-success w-100">

                            Crear Cuenta

                        </button>

                    </form>

                    <hr>

                    <div class="text-center">

                        ¿Ya tienes una cuenta?

                        <a asp-action="Login">

                            Iniciar Sesión

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}