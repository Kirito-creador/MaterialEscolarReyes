@{
    ViewData["Title"] = "Contacto";
    Layout = "~/Views/Shared/_LayoutTienda.cshtml";
}

<section class="bg-primary text-white py-5">

    <div class="container text-center">

        <h1 class="display-4 fw-bold">

            Contáctanos

        </h1>

        <p class="lead">

            Estamos listos para ayudarte.

        </p>

    </div>

</section>

<div class="container py-5">

    <div class="row">

        <!-- Información -->

        <div class="col-lg-5 mb-4">

            <div class="card shadow border-0">

                <div class="card-body">

                    <h3 class="mb-4">

                        Material Escolar Reyes

                    </h3>

                    <p>

                        <i class="bi bi-telephone-fill text-primary"></i>

                        <strong>Teléfono:</strong>

                        77487368

                    </p>

                    <p>

                        <i class="bi bi-clock-fill text-primary"></i>

                        <strong>Lunes a Viernes</strong>

                        <br />

                        07:00 - 20:00

                    </p>

                    <p>

                        <i class="bi bi-clock-fill text-primary"></i>

                        <strong>Sábado y Domingo</strong>

                        <br />

                        08:30 - 13:00

                    </p>

                    <p>

                        <i class="bi bi-shop text-primary"></i>

                        Venta de útiles escolares, oficina,
                        papelería y material educativo.

                    </p>

                </div>

            </div>

        </div>

        <!-- Formulario -->

        <div class="col-lg-7">

            <div class="card shadow border-0">

                <div class="card-body">

                    <h3 class="mb-4">

                        Envíanos un mensaje

                    </h3>

                    <form>

                        <div class="mb-3">

                            <label class="form-label">

                                Nombre

                            </label>

                            <input class="form-control" />

                        </div>

                        <div class="mb-3">

                            <label class="form-label">

                                Correo

                            </label>

                            <input type="email"
                                   class="form-control" />

                        </div>

                        <div class="mb-3">

                            <label class="form-label">

                                Mensaje

                            </label>

                            <textarea class="form-control"
                                      rows="5"></textarea>

                        </div>

                        <button class="btn btn-primary">

                            Enviar Mensaje

                        </button>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

<!-- MAPA -->

<div class="container pb-5">

    <div class="card shadow">

        <div class="card-body p-0">

            <iframe src="https://www.google.com/maps?q=Cochabamba,Bolivia&output=embed"
                    width="100%"
                    height="450"
                    style="border:0;"
                    loading="lazy">
            </iframe>

        </div>

    </div>

</div>