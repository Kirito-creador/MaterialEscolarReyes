@model IEnumerable<MaterialEscolarReyes.Models.Producto>

@{
    ViewData["Title"] = "Productos";
    Layout = "~/Views/Shared/_LayoutTienda.cshtml";
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold">

            Productos

        </h2>

        @if (!string.IsNullOrWhiteSpace(ViewBag.Buscar))
        {
            <span class="text-secondary">
                Resultados para: <strong>@ViewBag.Buscar</strong>
            </span>
        }

    </div>

    <div class="row">

        @if (!Model.Any())
        {
            <div class="col-12">

                <div class="alert alert-warning text-center">

                    No se encontraron productos.

                </div>

            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-lg-3 col-md-6 mb-4">

                    <div class="card producto-home shadow">

                        <span class="badge bg-danger position-absolute m-2">
                            Nuevo
                        </span>

                        @if (string.IsNullOrEmpty(item.ImagenPrincipal))
                        {
                            <img src="/images/no-image.png"
                                 class="card-img-top">
                        }
                        else
                        {
                            <img src="/uploads/productos/@item.ImagenPrincipal"
                                 class="card-img-top">
                        }

                        <div class="card-body">

                            <h5>@item.Nombre</h5>

                            <small class="text-secondary">

                                @item.Marca?.Nombre

                            </small>

                            <h4 class="text-primary mt-3">

                                Bs @item.PrecioVenta

                            </h4>

                            <a asp-controller="Tienda"
                               asp-action="Producto"
                               asp-route-id="@item.Id"
                               class="btn btn-primary w-100 mt-3">

                                Ver Producto

                            </a>

                        </div>

                    </div>

                </div>
            }
        }

    </div>

</div>