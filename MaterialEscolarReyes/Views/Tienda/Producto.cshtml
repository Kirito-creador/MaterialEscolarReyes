@model MaterialEscolarReyes.Models.Producto

@{
    ViewData["Title"] = Model.Nombre;
    Layout = "~/Views/Shared/_LayoutTienda.cshtml";
}

<div class="container py-5">

    <div class="row">

        <!-- IMÁGENES -->

        <div class="col-lg-6">

            <img id="imagenPrincipal"
                 src="/uploads/productos/@Model.ImagenPrincipal"
                 class="img-fluid rounded shadow mb-3"
                 style="width:100%;height:500px;object-fit:cover;">

            <div class="row">

                <div class="col-6">

                    <img src="/uploads/productos/@Model.ImagenPrincipal"
                         class="img-thumbnail miniatura"
                         style="cursor:pointer;height:150px;object-fit:cover;">

                </div>

                <div class="col-6">

                    @if (!string.IsNullOrEmpty(Model.ImagenSecundaria))
                    {
                        <img src="/uploads/productos/@Model.ImagenSecundaria"
                             class="img-thumbnail miniatura"
                             style="cursor:pointer;height:150px;object-fit:cover;">
                    }

                </div>

            </div>

        </div>

        <!-- INFORMACIÓN -->

        <div class="col-lg-6">

            <h2 class="fw-bold">

                @Model.Nombre

            </h2>

            <p class="text-secondary">

                Código:
                <strong>@Model.Codigo</strong>

            </p>

            <p>

                📂 Categoría:
                <strong>@Model.Categoria?.Nombre</strong>

            </p>

            <p>

                🏷 Marca:
                <strong>@Model.Marca?.Nombre</strong>

            </p>

            <hr>

            <h1 class="text-primary">

                Bs @Model.PrecioVenta

            </h1>

            <p class="text-success">

                <i class="bi bi-check-circle-fill"></i>

                Disponible

            </p>

            <hr>

            <h5>

                Descripción

            </h5>

            <p>

                @Model.Descripcion

            </p>

            <hr>

            <div class="d-flex align-items-center mb-4">

                <button class="btn btn-outline-secondary"
                        onclick="restar()">

                    -

                </button>

                <input id="cantidad"
                       value="1"
                       class="form-control text-center mx-2"
                       style="width:80px;">

                <button class="btn btn-outline-secondary"
                        onclick="sumar()">

                    +

                </button>

            </div>
            <button class="btn btn-success btn-lg w-100"
                    onclick="agregarCarrito(@Model.Id)">

                <i class="bi bi-cart-plus"></i>

                Agregar al carrito

            </button>

        </div>

    </div>

</div>

<section class="container mb-5">

    <h3 class="fw-bold mb-4">

        Productos Relacionados

    </h3>

    <div class="row">

        @foreach (var p in ViewBag.Relacionados)
        {

            <div class="col-lg-3">

                <div class="card shadow">

                    <img src="/uploads/productos/@p.ImagenPrincipal"
                         class="card-img-top"
                         style="height:220px;object-fit:cover;">

                    <div class="card-body">

                        <h6>

                            @p.Nombre

                        </h6>

                        <h5 class="text-primary">

                            Bs @p.PrecioVenta

                        </h5>

                        <a asp-action="Producto"
                           asp-route-id="@p.Id"
                           class="btn btn-primary w-100">

                            Ver

                        </a>

                    </div>

                </div>

            </div>

        }

    </div>

</section>

@section Scripts {

    <script>

        document.querySelectorAll(".miniatura").forEach(function(img){

        img.onclick=function(){

        document.getElementById("imagenPrincipal").src=this.src;

        }

        });

        function sumar(){

        let c=document.getElementById("cantidad");

        c.value=parseInt(c.value)+1;

        }

        function restar(){

        let c=document.getElementById("cantidad");

        if(parseInt(c.value)>1)

        c.value=parseInt(c.value)-1;

        }
                       async function agregarCarrito(id) {

            let cantidad = document.getElementById("cantidad").value;

            let respuesta = await fetch("/Carrito/Agregar", {

                method: "POST",

                headers: {
                    "Content-Type": "application/x-www-form-urlencoded"
                },

                body: `id=${id}&cantidad=${cantidad}`

            });

            let datos = await respuesta.json();

            if (datos.login) {

                Swal.fire({
                    icon: "warning",
                    title: "Debes iniciar sesión",
                    text: "Para agregar productos al carrito primero inicia sesión."
                }).then(() => {

                    window.location = "/CuentaCliente/Login";

                });

                return;
            }

            if (datos.ok) {

                document.getElementById("contadorCarrito").innerText = datos.total;

                Swal.fire({
                    icon: "success",
                    title: "Producto agregado",
                    text: "El producto fue agregado correctamente.",
                    timer: 1800,
                    showConfirmButton: false
                });

            }

        }

    </script>

}