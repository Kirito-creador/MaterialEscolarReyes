@{
    ViewData["Title"] = "Reportes";
}

<div class="container-fluid">

    <h2 class="fw-bold mb-4">

        <i class="bi bi-bar-chart-fill"></i>

        Centro de Reportes

    </h2>

    <div class="row">

        <div class="col-md-6 col-lg-4 mb-4">

            <div class="card shadow h-100">

                <div class="card-body text-center">

                    <i class="bi bi-cash-stack display-3 text-success"></i>

                    <h4 class="mt-3">

                        Reporte de Ventas

                    </h4>

                    <hr>

                    <a asp-action="VentasPdf"
                       class="btn btn-danger">

                        <i class="bi bi-file-earmark-pdf"></i>

                        PDF

                    </a>

                    <a asp-action="VentasExcel"
                       class="btn btn-success">

                        <i class="bi bi-file-earmark-excel"></i>

                        Excel

                    </a>

                </div>

            </div>

        </div>

        <div class="col-md-6 col-lg-4 mb-4">

            <div class="card shadow h-100">

                <div class="card-body text-center">

                    <i class="bi bi-box-seam display-3 text-primary"></i>

                    <h4 class="mt-3">

                        Productos

                    </h4>

                    <hr>

                    <a asp-action="ProductosPdf"
                       class="btn btn-danger">

                        PDF

                    </a>

                    <a asp-action="ProductosExcel"
                       class="btn btn-success">

                        Excel

                    </a>

                </div>

            </div>

        </div>

        <div class="col-md-6 col-lg-4 mb-4">

            <div class="card shadow h-100">

                <div class="card-body text-center">

                    <i class="bi bi-people display-3 text-info"></i>

                    <h4 class="mt-3">

                        Clientes

                    </h4>

                    <hr>

                    <a asp-action="ClientesPdf"
                       class="btn btn-danger">

                        PDF

                    </a>

                    <a asp-action="ClientesExcel"
                       class="btn btn-success">

                        Excel

                    </a>

                </div>

            </div>

        </div>

        <div class="col-md-6 col-lg-4 mb-4">

            <div class="card shadow h-100">

                <div class="card-body text-center">

                    <i class="bi bi-truck display-3 text-warning"></i>

                    <h4 class="mt-3">

                        Proveedores

                    </h4>

                    <hr>

                    <a asp-action="ProveedoresPdf"
                       class="btn btn-danger">

                        PDF

                    </a>

                    <a asp-action="ProveedoresExcel"
                       class="btn btn-success">

                        Excel

                    </a>

                </div>

            </div>

        </div>

        <div class="col-md-6 col-lg-4 mb-4">

            <div class="card shadow h-100">

                <div class="card-body text-center">

                    <i class="bi bi-exclamation-triangle display-3 text-danger"></i>

                    <h4 class="mt-3">

                        Stock Bajo

                    </h4>

                    <hr>

                    <a asp-action="StockPdf"
                       class="btn btn-danger">

                        PDF

                    </a>

                    <a asp-action="StockExcel"
                       class="btn btn-success">

                        Excel

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>