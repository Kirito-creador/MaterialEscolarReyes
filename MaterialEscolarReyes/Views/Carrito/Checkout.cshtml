@model MaterialEscolarReyes.ViewModels.CheckoutViewModel

@{
    ViewData["Title"] = "Finalizar Compra";
    Layout = "~/Views/Shared/_LayoutTienda.cshtml";
}

<div class="container py-5">

    <h2 class="fw-bold mb-4">

        Finalizar Compra

    </h2>

    <form asp-action="Checkout" method="post">

        <div class="card shadow">

            <div class="card-body">

                <div class="mb-3">

                    <label>Dirección</label>

                    <input asp-for="Direccion"
                           class="form-control" />

                </div>

                <div class="mb-3">

                    <label>Teléfono</label>

                    <input asp-for="Telefono"
                           class="form-control" />

                </div>

                <div class="mb-3">

                    <label>Método de Pago</label>

                    <select asp-for="MetodoPago"
                            class="form-select">

                        <option value="">Seleccione...</option>

                        <option>Efectivo</option>

                        <option>Transferencia</option>

                        <option>QR</option>

                    </select>

                </div>

                <h3 class="text-success">

                    Total: Bs @Model.Total

                </h3>

                <button class="btn btn-success btn-lg">

                    Confirmar Compra

                </button>

            </div>

        </div>

    </form>

</div>