@model MaterialEscolarReyes.Models.Venta

@{
    ViewData["Title"] = "Detalle de Venta";
}

<div class="container-fluid">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">

            <h3>

                <i class="bi bi-receipt"></i>

                Venta N° @Model.NumeroVenta

            </h3>

        </div>

        <div class="card-body">

            <div class="row mb-4">

                <div class="col-md-4">

                    <strong>Cliente</strong>

                    <p>@Model.Cliente?.Nombre</p>

                </div>

                <div class="col-md-4">

                    <strong>Fecha</strong>

                    <p>@Model.Fecha.ToString("dd/MM/yyyy HH:mm")</p>

                </div>

                <div class="col-md-4">

                    <strong>Vendedor</strong>

                    <p>@Model.Usuario?.Nombre</p>

                </div>

            </div>

            <table class="table table-bordered table-striped">

                <thead class="table-dark">

                    <tr>

                        <th>Producto</th>
                        <th>Cantidad</th>
                        <th>Precio</th>
                        <th>Subtotal</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model.Detalles!)
                    {

                        <tr>

                            <td>@item.Producto?.Nombre</td>

                            <td>@item.Cantidad</td>

                            <td>Bs @item.PrecioUnitario</td>

                            <td>Bs @item.Subtotal</td>

                        </tr>

                    }

                </tbody>

            </table>

            <div class="text-end">

                <h3 class="text-success">

                    TOTAL Bs @Model.Total

                </h3>

            </div>

            <hr />

            <a asp-action="Index"
               class="btn btn-secondary">

                Volver

            </a>

        </div>

    </div>

</div>