@model MaterialEscolarReyes.Models.Proveedor

@{
    ViewData["Title"] = "Editar Proveedor";
}

<h2 class="mb-4">

    <i class="bi bi-pencil-square"></i>

    Editar Proveedor

</h2>

<form asp-action="Edit">

    <input asp-for="Id" type="hidden" />

    <div class="card shadow">

        <div class="card-body">

            <div class="mb-3">

                <label asp-for="Nombre"></label>

                <input asp-for="Nombre"
                       class="form-control" />

            </div>

            <div class="mb-3">

                <label asp-for="Telefono"></label>

                <input asp-for="Telefono"
                       class="form-control" />

            </div>

            <div class="mb-3">

                <label asp-for="Correo"></label>

                <input asp-for="Correo"
                       class="form-control" />

            </div>

            <div class="mb-3">

                <label asp-for="Direccion"></label>

                <textarea asp-for="Direccion"
                          class="form-control"></textarea>

            </div>

            <hr />

            <button class="btn btn-success">

                Guardar Cambios

            </button>

            <a asp-action="Index"
               class="btn btn-secondary">

                Cancelar

            </a>

        </div>

    </div>

</form>