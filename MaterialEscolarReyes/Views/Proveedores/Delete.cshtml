@model MaterialEscolarReyes.Models.Proveedor

@{
    ViewData["Title"] = "Eliminar";
}

<div class="card shadow">

    <div class="card-header bg-danger text-white">

        <h3>

            Eliminar Proveedor

        </h3>

    </div>

    <div class="card-body">

        <h5>

            ¿Desea eliminar este proveedor?

        </h5>

        <hr />

        <p>

            <strong>@Model.Nombre</strong>

        </p>

        <p>

            @Model.Correo

        </p>

        <form asp-action="Delete">

            <input asp-for="Id"
                   type="hidden" />

            <button class="btn btn-danger">

                Sí, eliminar

            </button>

            <a asp-action="Index"
               class="btn btn-secondary">

                Cancelar

            </a>

        </form>

    </div>

</div>