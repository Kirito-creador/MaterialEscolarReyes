<!DOCTYPE html>
<html lang="es">
<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - Material Escolar Reyes</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
          rel="stylesheet" />

    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">

    <link href="~/css/tienda.css"
          rel="stylesheet" />

    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#0d6efd">
    <link rel="apple-touch-icon" href="/images/icon-192.png">

</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">

        <div class="container">

            <a class="navbar-brand fw-bold"
               asp-controller="Tienda"
               asp-action="Index">

                📚 Material Escolar Reyes

            </a>

            <button class="navbar-toggler"
                    data-bs-toggle="collapse"
                    data-bs-target="#menu">

                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse"
                 id="menu">

                <ul class="navbar-nav mx-auto">

                    <li class="nav-item">

                        <a class="nav-link"
                           asp-controller="Tienda"
                           asp-action="Index">

                            Inicio

                        </a>

                    </li>
                    <li class="nav-item">
    <a class="nav-link"
       asp-controller="Tienda"
       asp-action="Productos">
        Productos
    </a>
</li>

<li class="nav-item">
    <a class="nav-link"
       asp-controller="Tienda"
       asp-action="Categorias">
        Categorías
    </a>
</li>

<li class="nav-item">
    <a class="nav-link"
       asp-controller="Tienda"
       asp-action="Ofertas">
        Ofertas
    </a>
</li>

<li class="nav-item">
    <a class="nav-link"
       asp-controller="Tienda"
       asp-action="Contacto">
        Contacto
    </a>
</li>
           
                </ul>

                <form class="d-flex"
                      asp-controller="Tienda"
                      asp-action="Productos"
                      method="get">

                    <input class="form-control me-2"
                           type="search"
                           name="buscar"
                           value="@Context.Request.Query["buscar"]"
                           placeholder="Buscar productos..." />

                    <button class="btn btn-primary"
                            type="submit">

                        <i class="bi bi-search"></i>

                    </button>

                </form>

                @if (Context.Session.GetInt32("ClienteId") == null)
{
    <a asp-controller="CuentaCliente"
       asp-action="Login"
       class="btn btn-outline-primary ms-3">

        <i class="bi bi-person"></i>

        Mi Cuenta

    </a>
}
else
{
    <div class="dropdown ms-3">

        <button class="btn btn-primary dropdown-toggle"
                type="button"
                data-bs-toggle="dropdown"
                aria-expanded="false">

            <i class="bi bi-person-circle"></i>

            @Context.Session.GetString("ClienteNombre")

        </button>

        <ul class="dropdown-menu dropdown-menu-end">

            <li>

                <a class="dropdown-item"
                   asp-controller="CuentaCliente"
                   asp-action="Perfil">

                    Mi Perfil

                </a>

            </li>

            <li>

                <a class="dropdown-item"
                   asp-controller="Carrito"
                   asp-action="Index">

                    Mi Carrito

                </a>

            </li>

            <li>

                <a class="dropdown-item"
                   asp-controller="CuentaCliente"
                   asp-action="MisPedidos">

                    <i class="bi bi-bag-check"></i>

                    Mis Compras

                </a>

            </li>

            <li>
                <hr class="dropdown-divider">
            </li>

            <li>

                <a class="dropdown-item"
                   asp-controller="CuentaCliente"
                   asp-action="Logout">

                    Cerrar Sesión

                </a>

            </li>

        </ul>

    </div>
}

                    </a>

                </a>

                <a asp-controller="Carrito"
                   asp-action="Index"
                   class="btn btn-primary ms-2 position-relative">

                    <i class="bi bi-cart3"></i>

                    <span id="contadorCarrito"
                          class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">

                        0

                    </span>

                </a>

            </div>

        </div>

    </nav>

    <main>

        @RenderBody()

    </main>

    <footer class="bg-dark text-white mt-5">

        <div class="container py-5">

            <div class="row">

                <div class="col-md-4">

                    <h4>

                        Material Escolar Reyes

                    </h4>

                    <p>

                        Todo para el estudiante en un solo lugar.

                    </p>

                </div>

                <div class="col-md-4">

                    <h5>

                        Contacto

                    </h5>

                    <p>

                        Cochabamba - Bolivia

                    </p>

                    <p>

                        WhatsApp

                    </p>

                </div>

                <div class="col-md-4">

                    <h5>

                        Redes Sociales

                    </h5>

                    <i class="bi bi-facebook fs-3 me-3"></i>

                    <i class="bi bi-instagram fs-3 me-3"></i>

                    <i class="bi bi-whatsapp fs-3"></i>

                </div>

            </div>

        </div>

    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/tienda.js"></script>


    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('/service-worker.js');
    }
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>